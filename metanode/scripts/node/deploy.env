#!/bin/bash
# ╔═══════════════════════════════════════════════════════════════════╗
# ║  MULTI-SERVER DEPLOYMENT CONFIG                                   ║
# ║  Edit this file once, then run deploy_cluster.sh                  ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ─── SSH Config ──────────────────────────────────────────────────────
SSH_USER="abc"

# Authentication method: "key" or "password"
SSH_AUTH="password"

# For key auth: path to SSH key (leave empty for default ~/.ssh/id_rsa)
SSH_KEY=""

# For password auth: SSH password (requires sshpass installed)
SSH_PASSWORD="your_password_here"

# SSH options (skip host key checking for automation)
SSH_OPTS="-o StrictHostKeyChecking=no -o ConnectTimeout=10"

# ─── Server IPs ─────────────────────────────────────────────────────
# 3 servers, 4 validator nodes distributed across them
# Adjust to your actual server IPs

SERVER_A="192.168.1.40"    # Node 0 (Leader/Primary validator)
SERVER_B="192.168.1.231"   # Node 1
SERVER_C="192.168.1.232"   # Node 2, Node 3

# ─── Node → Server Mapping ──────────────────────────────────────────
# Which nodes run on which server
# Format: NODE_SERVER[node_id]="server_ip"
declare -A NODE_SERVER
NODE_SERVER[0]="$SERVER_A"
NODE_SERVER[1]="$SERVER_B"
NODE_SERVER[2]="$SERVER_C"
NODE_SERVER[3]="$SERVER_C"

# ─── Project Paths (must be same on all servers) ────────────────────
REMOTE_CHAIN_DIR="/home/${SSH_USER}/chain-n"
REMOTE_MTN_CONSENSUS="${REMOTE_CHAIN_DIR}/mtn-consensus"
REMOTE_MTN_SIMPLE="${REMOTE_CHAIN_DIR}/mtn-simple-2025"
REMOTE_METANODE="${REMOTE_MTN_CONSENSUS}/metanode"
REMOTE_SCRIPTS="${REMOTE_METANODE}/scripts/node"
REMOTE_GO_SIMPLE="${REMOTE_MTN_SIMPLE}/cmd/simple_chain"

# ─── Build Config ───────────────────────────────────────────────────
# Build on which server? ("local" = build here, or IP = build on that server)
# "local" builds locally then rsync binaries to all servers (faster if you have fast local build)
# Setting a server IP builds on that server then rsync to others
BUILD_SERVER="local"

# Rust toolchain
RUST_TOOLCHAIN="nightly"

# Go toolchain
GO_TOOLCHAIN="go1.23.5"

# ─── Sync Config ────────────────────────────────────────────────────
# Method: "rsync" (full sync) or "git" (git pull on each server)
SYNC_METHOD="rsync"

# Directories to sync (relative to REMOTE_CHAIN_DIR)
SYNC_DIRS=("mtn-consensus" "mtn-simple-2025")

# Exclude patterns for rsync
RSYNC_EXCLUDES=(
    "target/"
    "*.o"
    "*.a"
    "sample/*/data/"
    "sample/*/data-write/"
    "sample/*/back_up*"
    "config/storage/"
    "logs/"
    "snapshot_data*"
    ".git/"
    "node_modules/"
)
